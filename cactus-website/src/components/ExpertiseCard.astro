---
interface Props {
    title: string;
    description: string;
    href: string;
    icon: string;
    tags?: string[];
    delay?: number;
}

const { title, description, href, icon, tags, delay = 1 } = Astro.props;

const iconPaths: Record<string, string> = {
    table: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/>',
    database: '<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>',
    shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
    server: '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
    code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/>',
};
---

<a href={href}
   class={`group relative block reveal reveal-delay-${delay}`}>
    <div class="bg-white border rounded-2xl p-8 overflow-hidden transition-all duration-300 group-hover:-translate-y-1.5 group-hover:shadow-lg group-hover:border-cactus-green"
         style="border-color: var(--color-cloud-dark);">
        <!-- Top bar animation -->
        <div class="card-top-bar"></div>
        <!-- Icon -->
        <div class="w-[52px] h-[52px] rounded-[10px] flex items-center justify-center mb-5 transition-colors"
             style="background: rgba(219,204,99,0.15);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 style="color: var(--color-amber);">
                <Fragment set:html={iconPaths[icon] || iconPaths.code} />
            </svg>
        </div>
        <h3 class="font-heading font-semibold text-lg mb-2" style="color: var(--color-ink);">{title}</h3>
        <p class="text-sm leading-relaxed mb-5" style="color: var(--color-ink-soft);">{description}</p>
        {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
                {tags.map(tag => (
                    <span class="inline-flex items-center text-xs font-heading font-semibold px-2.5 py-1 rounded-full"
                          style="background: rgba(71,106,51,0.08); color: var(--color-cactus-green);">{tag}</span>
                ))}
            </div>
        )}
        <span class="inline-flex items-center gap-1 font-heading font-semibold text-xs group-hover:gap-2 transition-all"
              style="color: var(--color-cactus-green);">
            En savoir plus
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
        </span>
    </div>
</a>
