---
interface Step {
    num: string;
    title: string;
    text: string;
}

interface Props {
    steps: Step[];
    expanded?: boolean;
}

const { steps, expanded = false } = Astro.props;
---

<div class={`grid grid-cols-1 ${expanded ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-4'} gap-8 relative`}>
    <!-- Connecting line (desktop, compact mode) -->
    {!expanded && (
        <div class="hidden lg:block absolute top-[26px] h-[2px]"
             style="left: calc(12.5% + 18px); right: calc(12.5% + 18px); background: var(--color-cloud-dark);">
            <div class="timeline-line-fill"></div>
        </div>
    )}
    {steps.map((step, i) => (
        <div class={`${expanded ? '' : 'text-center'} relative reveal reveal-delay-${i + 1}`}>
            <div class={`w-[52px] h-[52px] rounded-full flex items-center justify-center ${expanded ? 'mb-4' : 'mx-auto mb-5'} relative z-[2] font-heading font-bold text-lg text-white`}
                 style="background: var(--color-cactus-green); box-shadow: 0 0 0 6px var(--color-cloud);">
                {step.num}
            </div>
            <h3 class={`font-heading font-semibold ${expanded ? 'text-lg' : 'text-base'} mb-2`}
                style="color: var(--color-ink);">
                {step.title}
            </h3>
            <p class={`text-sm leading-relaxed ${expanded ? 'max-w-[480px]' : ''}`}
               style="color: var(--color-ink-soft);">
                {step.text}
            </p>
        </div>
    ))}
</div>
