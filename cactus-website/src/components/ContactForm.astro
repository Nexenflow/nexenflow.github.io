---
interface Props {
    variant?: 'standard' | 'urgency';
    lang: string;
}

const { variant = 'standard', lang } = Astro.props;
const isUrgency = variant === 'urgency';

const standardOptions = [
    'ERP & Gestion d\'entreprise',
    'Migration de données',
    'Cybersécurité',
    'Infrastructure & Cloud',
    'Développement sur mesure',
    'Nos Produits — Catalogue',
    'IoT & Connectivité',
    'Audit & Diagnostic IT',
    'Accompagnement sectoriel',
    'Urgence IT',
    'Autre',
];

const urgencyOptions = [
    'ERP bloqué / inaccessible',
    'Incident cybersécurité / intrusion',
    'Panne serveur critique',
    'Perte de données',
    'Migration échouée',
    'Autre urgence',
];

const options = isUrgency ? urgencyOptions : standardOptions;
// Follow the website's form chart (use light classes for both standard and urgency)
const inputClass = 'form-input';
const labelClass = 'form-label';
---

<form id={isUrgency ? 'urgency-form' : 'contact-form'}
      class="space-y-5"
      action={isUrgency ? '/api/urgence.php' : '/api/contact.php'}
      method="POST">

    <input type="hidden" name="source_url" id="contact-source-url" value="" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
            <label class={labelClass} for="nom">Nom complet *</label>
            <input type="text" id="nom" name="nom" required placeholder="Ex: M. Karim Benjelloun"
                   class={inputClass} />
            {isUrgency && <span class="text-[10px] text-ink-muted mt-1 block">Votre nom pour la prise de contact direct</span>}
        </div>
        <div>
            <label class={labelClass} for="entreprise">Entreprise *</label>
            <input type="text" id="entreprise" name="entreprise" required placeholder="Ex: SOREC S.A."
                   class={inputClass} />
            {isUrgency && <span class="text-[10px] text-ink-muted mt-1 block">Raison sociale de la société impactée</span>}
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {!isUrgency && (
            <div>
                <label class={labelClass} for="email">Email professionnel *</label>
                <input type="email" id="email" name="email" required placeholder="email@entreprise.ma"
                       class={inputClass} />
            </div>
        )}
        <div>
            <label class={labelClass} for="telephone">Téléphone direct *</label>
            <input type="tel" id="telephone" name="telephone" required placeholder="Ex: +212 6 61 12 34 56"
                   class={inputClass} />
            {isUrgency && <span class="text-[10px] text-ink-muted mt-1 block">Rappel immédiat sous 2 heures ouvrées</span>}
        </div>
        {isUrgency && (
            <div>
                <label class={labelClass} for="email">Adresse Email *</label>
                <input type="email" id="email" name="email" required placeholder="email@entreprise.ma"
                       class={inputClass} />
                <span class="text-[10px] text-ink-muted mt-1 block">Pour l'envoi du rapport d'intervention</span>
            </div>
        )}
    </div>

    <div>
        <label class={labelClass} for="besoin">
            {isUrgency ? 'Type d\'urgence technique *' : 'Besoin *'}
        </label>
        <select id="besoin" name="besoin" required
                class={`${inputClass} cursor-pointer`}>
            <option value="">{isUrgency ? "— Sélectionnez le type d'incident —" : "— Sélectionnez votre besoin —"}</option>
            {options.map(opt => (
                <option value={opt}>{opt}</option>
            ))}
        </select>
        {isUrgency && <span class="text-[10px] text-ink-muted mt-1 block">Sélectionnez la catégorie qui décrit le mieux la panne</span>}
    </div>

    <div>
        <label class={labelClass} for="message">
            {isUrgency ? 'Description détaillée de la situation *' : 'Message *'}
        </label>
        <textarea id="message" name="message" required rows="4"
                  placeholder={isUrgency ? 'Décrivez la panne ou l\'incident (Ex: Base de données SQL corrompue suite à panne de disque, ERP inaccessible depuis 8h...)' : 'Décrivez votre besoin en quelques lignes...'}
                  class={inputClass}></textarea>
        {isUrgency && <span class="text-[10px] text-ink-muted mt-1 block">Détaillez les messages d'erreur ou les symptômes visibles</span>}
    </div>

    <!-- Honeypot field (hidden from human users, visible to bots) -->
    <div class="hidden" aria-hidden="true">
        <label class="form-label" for="fax">Fax</label>
        <input type="text" id="fax" name="fax" tabindex="-1" autocomplete="off" class="form-input" />
    </div>

    <!-- Feedback Container -->
    <div id="form-feedback" class="hidden rounded-xl p-4 text-sm font-medium transition-all duration-300"></div>

    <button type="submit"
            class={`magnetic-btn w-full md:w-auto inline-flex items-center justify-center gap-2.5 font-heading font-bold text-sm rounded-full px-8 py-4.5 text-white transition-all hover:-translate-y-0.5 hover:shadow-xl cursor-pointer`}
            style={`background: var(--color-${isUrgency ? 'earth-brown' : 'cactus-green'});`}>
        {isUrgency ? (
            <>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/>
                    <path d="M12 9v4"/><path d="M12 17h.01"/>
                </svg>
                Déclencher l'alerte d'urgence IT
            </>
        ) : (
            <>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
                </svg>
                Envoyer le message
            </>
        )}
    </button>

    <p class="text-xs mt-3" style={`color: var(--color-ink-muted);`}>
        {isUrgency ? '✓ Un ingénieur senior prend contact avec vous sous 2h. Facturation au résultat.' : 'Nous vous répondons sous 24 heures ouvrées.'}
    </p>
</form>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const select = document.getElementById('besoin') as HTMLSelectElement | null;
        if (select) {
            const params = new URLSearchParams(window.location.search);
            const besoinParam = params.get('besoin');
            
            if (besoinParam) {
                const mapping: Record<string, string> = {
                    'erp': "ERP & Gestion d'entreprise",
                    'migration': "Migration de données",
                    'cybersecurite': "Cybersécurité",
                    'infrastructure': "Infrastructure & Cloud",
                    'developpement': "Développement sur mesure",
                    'produits': "Nos Produits — Catalogue",
                    'iot': "IoT & Connectivité",
                    'audit': "Audit & Diagnostic IT",
                    'secteur': "Accompagnement sectoriel",
                    'urgence': "Urgence IT"
                };
                
                const targetVal = mapping[besoinParam.toLowerCase()];
                if (targetVal) {
                    for (let i = 0; i < select.options.length; i++) {
                        if (select.options[i].value === targetVal) {
                            select.selectedIndex = i;
                            break;
                        }
                    }
                }
            }
        }

        const sourceInput = document.getElementById('contact-source-url') as HTMLInputElement | null;
        if (sourceInput) {
            sourceInput.value = document.referrer || window.location.href;
        }

        const form = (document.getElementById('contact-form') || document.getElementById('urgency-form')) as HTMLFormElement | null;
        if (form) {
            form.addEventListener('submit', async (e: Event) => {
                e.preventDefault();

                const nameInput = form.querySelector('#nom') as HTMLInputElement | null;
                const companyInput = form.querySelector('#entreprise') as HTMLInputElement | null;
                const emailInput = form.querySelector('#email') as HTMLInputElement | null;
                const phoneInput = form.querySelector('#telephone') as HTMLInputElement | null;
                const serviceSelect = form.querySelector('#besoin') as HTMLSelectElement | null;
                const messageInput = form.querySelector('#message') as HTMLTextAreaElement | null;
                const feedbackDiv = form.querySelector('#form-feedback') as HTMLDivElement | null;
                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
                const honeypotInput = form.querySelector('#fax') as HTMLInputElement | null;

                const showFeedback = (msg: string, type: 'success' | 'error') => {
                    if (!feedbackDiv) return;
                    feedbackDiv.innerText = msg;
                    feedbackDiv.classList.remove('hidden');
                    if (type === 'success') {
                        feedbackDiv.style.background = 'rgba(71, 106, 51, 0.08)';
                        feedbackDiv.style.color = 'var(--color-cactus-green)';
                        feedbackDiv.style.border = '1px solid rgba(71, 106, 51, 0.2)';
                    } else {
                        feedbackDiv.style.background = 'rgba(111, 50, 3, 0.08)';
                        feedbackDiv.style.color = 'var(--color-earth-brown)';
                        feedbackDiv.style.border = '1px solid rgba(111, 50, 3, 0.2)';
                    }
                };

                // Clear previous feedback
                if (feedbackDiv) {
                    feedbackDiv.classList.add('hidden');
                    feedbackDiv.innerText = '';
                }

                const name = nameInput?.value.trim() || '';
                const email = emailInput?.value.trim() || '';
                const message = messageInput?.value.trim() || '';
                const company = companyInput?.value.trim() || '';
                const phone = phoneInput?.value.trim() || '';
                const service = serviceSelect?.value || '';
                const fax = honeypotInput?.value || '';

                // If honeypot is filled, treat as bot submission. Reject and return fake success.
                if (fax) {
                    console.warn('Bot submission blocked.');
                    showFeedback("Votre message a été envoyé avec succès. Merci !", 'success');
                    form.reset();
                    const sourceInput = form.querySelector('#contact-source-url') as HTMLInputElement | null;
                    if (sourceInput) {
                        sourceInput.value = document.referrer || window.location.href;
                    }
                    return;
                }

                // Validation checks
                if (!name) {
                    showFeedback("Veuillez renseigner votre nom complet.", 'error');
                    return;
                }
                if (name.length > 255) {
                    showFeedback("Le nom complet ne peut pas dépasser 255 caractères.", 'error');
                    return;
                }

                if (!email) {
                    showFeedback("Veuillez renseigner votre adresse email.", 'error');
                    return;
                }
                if (email.length > 255) {
                    showFeedback("L'adresse email ne peut pas dépasser 255 caractères.", 'error');
                    return;
                }
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(email)) {
                    showFeedback("Veuillez saisir une adresse email valide.", 'error');
                    return;
                }

                if (!message) {
                    showFeedback("Veuillez saisir votre message.", 'error');
                    return;
                }
                if (message.length > 4000) {
                    showFeedback("Le message ne peut pas dépasser 4000 caractères.", 'error');
                    return;
                }

                if (company && company.length > 255) {
                    showFeedback("Le nom de l'entreprise ne peut pas dépasser 255 caractères.", 'error');
                    return;
                }

                if (phone && phone.length > 50) {
                    showFeedback("Le numéro de téléphone ne peut pas dépasser 50 caractères.", 'error');
                    return;
                }

                if (!service) {
                    showFeedback("Veuillez sélectionner un besoin.", 'error');
                    return;
                }
                if (service.length > 100) {
                    showFeedback("Le service sélectionné est invalide.", 'error');
                    return;
                }

                // API request payload preparation
                const isUrgencyForm = form.id === 'urgency-form';
                const subject = isUrgencyForm ? "Signalement d'urgence" : "Demande de contact";

                const payload = {
                    name,
                    company,
                    email,
                    phone,
                    subject,
                    service,
                    message,
                    sourceWebsite: window.location.href,
                    fax
                };

                // Disable inputs
                const inputs = Array.from(form.elements) as (HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement)[];
                inputs.forEach(input => {
                    input.disabled = true;
                });

                // Show loading state on button
                const originalBtnContent = submitBtn?.innerHTML || '';
                if (submitBtn) {
                    submitBtn.innerHTML = `
                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Envoi en cours...
                    `;
                }

                try {
                    const response = await fetch('https://nerobel.nexenflow.com/api/public/contact', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-API-Key': 'ca_pub_pEidrlnNqnKnR-4ScfXY1P_rf3h8lUhr'
                        },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        showFeedback("Votre message a été envoyé avec succès. Merci !", 'success');
                        form.reset();
                        // Restore referral URL input value
                        const sourceInput = form.querySelector('#contact-source-url') as HTMLInputElement | null;
                        if (sourceInput) {
                            sourceInput.value = document.referrer || window.location.href;
                        }
                    } else {
                        const errorText = await response.text();
                        console.error('API Error:', response.status, errorText);
                        showFeedback("Une erreur est survenue lors de l'envoi. Veuillez réessayer.", 'error');
                    }
                } catch (err) {
                    console.error('Network Error:', err);
                    showFeedback("Erreur de connexion. Veuillez vérifier votre réseau et réessayer.", 'error');
                } finally {
                    // Re-enable elements
                    inputs.forEach(input => {
                        input.disabled = false;
                    });
                    if (submitBtn) {
                        submitBtn.innerHTML = originalBtnContent;
                    }
                }
            });
        }
    });
</script>
