---
interface Props {
    badge: string;
    client: string;
    description: string;
    tags: string[];
    href?: string;
    delay?: number;
}

const { badge, client, description, tags, href, delay = 1 } = Astro.props;
---

<div class={`group flex flex-col bg-white border rounded-2xl p-8 transition-all hover:-translate-y-1 hover:shadow-lg hover:border-cactus-green reveal reveal-delay-${delay}`}
     style="border-color: var(--color-cloud-dark);">
    <div class="card-top-bar"></div>
    <span class="inline-flex items-center w-fit text-xs font-heading font-semibold px-3 py-1 rounded-full mb-4"
          style="background: rgba(211,157,76,0.12); color: var(--color-earth-brown);">
        {badge}
    </span>
    <h3 class="font-heading font-bold text-lg mb-2" style="color: var(--color-ink);">{client}</h3>
    <p class="text-sm leading-relaxed mb-5 flex-grow" style="color: var(--color-ink-soft);">{description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => (
            <span class="inline-flex items-center text-xs font-heading font-semibold px-2.5 py-1 rounded-full"
                  style="background: rgba(71,106,51,0.08); color: var(--color-cactus-green);">
                {tag}
            </span>
        ))}
    </div>
    {href && (
        <a href={href}
           class="inline-flex items-center gap-1 font-heading font-semibold text-xs group-hover:gap-2 transition-all mt-auto"
           style="color: var(--color-cactus-green);">
            Voir le cas client
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
        </a>
    )}
</div>
