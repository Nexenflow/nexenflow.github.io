---
interface Props {
    title?: string;
    phone?: string;
    text?: string;
    ctaHref: string;
    ctaLabel: string;
}

const {
    title = "ERP bloqué, panne serveur, incident de sécurité ?",
    phone = "+212 5 22 34 35 45",
    text = "Nous intervenons comme experts de dernier recours. Réponse sous 2 heures ouvrées.",
    ctaHref,
    ctaLabel
} = Astro.props;
---

<section class="relative text-center py-16 overflow-hidden" style="background: linear-gradient(135deg, var(--color-earth-brown) 0%, var(--color-earth-deep) 100%);">
    <!-- Glow -->
    <div class="absolute w-[500px] h-[500px] rounded-full -top-[200px] -right-[100px] pointer-events-none"
         style="background: radial-gradient(circle, rgba(219,204,99,0.08) 0%, transparent 60%);"></div>
    <div class="max-w-[1200px] mx-auto px-6 relative z-[1]">
        <p class="font-heading font-semibold text-xs uppercase tracking-widest mb-4 reveal" style="color: var(--color-gold);">
            Intervention d'urgence
        </p>
        <h2 class="font-heading font-bold text-white mb-4 reveal" style="font-size: clamp(1.4rem, 3vw, 2.2rem);">
            {title}
        </h2>
        <div class="font-heading font-extrabold mb-6 reveal" style="font-size: clamp(1.6rem, 4vw, 2.8rem); color: var(--color-gold);">
            {phone}
        </div>
        <p class="text-base mb-8 reveal" style="color: rgba(255,255,255,0.7);">{text}</p>
        <div class="reveal">
            <a href={ctaHref}
               class="magnetic-btn inline-flex items-center gap-2 font-heading font-semibold text-base rounded-full px-8 py-4 transition-all hover:-translate-y-0.5 hover:shadow-lg"
               style="background: var(--color-gold); color: var(--color-cactus-dark);">
                {ctaLabel}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/>
                    <path d="M12 9v4"/><path d="M12 17h.01"/>
                </svg>
            </a>
        </div>
    </div>
</section>
