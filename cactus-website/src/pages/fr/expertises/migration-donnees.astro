---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureTable from '../../../components/FeatureTable.astro';
import CaseStudyCard from '../../../components/CaseStudyCard.astro';
import FaqAccordion from '../../../components/FaqAccordion.astro';
import UrgencyBanner from '../../../components/UrgencyBanner.astro';
import FinalCta from '../../../components/FinalCta.astro';
import { getLocalePath } from '../../../i18n/utils';

const lang = 'fr';
const p = (path: string) => getLocalePath(lang, path);

const services = [
    { title: 'Migration de systèmes et de données', desc: 'Migrations fluides et sécurisées entre plateformes hétérogènes. Nous re-structurons vos données pour les optimiser dans leur nouvel environnement.', items: ['Excel → ERP', 'Sage 1000 / Sage X3 → ERP Cactus', 'SAP → nouvelle architecture', 'AS400 → SQL Server', 'Tout système legacy → plateforme moderne'] },
    { title: 'Audit de bases de données', desc: 'Intervention chirurgicale au niveau de la BDD pour résoudre des anomalies de synchronisation structurelles que d\'autres intégrateurs ne parviennent pas à corriger.', items: [] },
    { title: 'Interfaçage de systèmes hétérogènes', desc: 'Quand deux systèmes qui n\'ont pas été conçus pour communiquer doivent échanger des données en temps réel.', items: [] },
    { title: 'Récupération de données', desc: 'Service d\'extraction et de récupération de données sur disques durs ou serveurs endommagés. Diagnostic transparent.', items: [] },
    { title: 'Pipelines d\'intégrité de données', desc: 'Flux garantissant l\'intégrité de la donnée de bout en bout : de la source jusqu\'à la destination.', items: [] },
];
---

<BaseLayout
    title="Migration de Données & Systèmes — Cactus"
    description="Migration de données sécurisée entre plateformes hétérogènes avec garantie de résultat. AS400, SQL Server, Sage, SAP, Excel. Récupération de données."
>
    <PageHero
        label="Migration & Données"
        title="Migration de données — "
        titleHighlight="fluide, sécurisée, garantie"
        subtitle="Depuis plus de vingt ans, nous fiabilisons, migrons et structurons les données d'entreprises marocaines et internationales — avec la garantie de résultat."
        breadcrumbs={[
            { label: 'Expertises', href: p('/expertises/') },
            { label: 'Migration & Données' },
        ]}
        lang={lang}
        ctaHref={p('/contact/') + '?besoin=migration'}
        ctaLabel="Diagnostic gratuit"
    />

    <!-- Services -->
    <section class="py-24">
        <div class="max-w-[1200px] mx-auto px-6">
            <SectionHeader
                label="Nos expertises"
                title="Maîtriser le cycle de vie de la donnée"
                subtitle="Votre donnée est un actif stratégique — traitez-la comme tel."
            />
            <div class="space-y-6 mt-2">
                {services.map((svc, i) => (
                    <div class={`bg-white border rounded-2xl p-8 transition-all hover:shadow-md hover:border-cactus-green reveal reveal-delay-${(i % 3) + 1}`}
                         style="border-color: var(--color-cloud-dark);">
                        <div class="card-top-bar"></div>
                        <div class="flex items-start gap-5">
                            <div class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center font-heading font-bold text-sm text-white" style="background: var(--color-cactus-green);">
                                {String(i + 1).padStart(2, '0')}
                            </div>
                            <div>
                                <h3 class="font-heading font-semibold text-lg mb-2" style="color: var(--color-ink);">{svc.title}</h3>
                                <p class="text-sm leading-relaxed mb-3" style="color: var(--color-ink-soft);">{svc.desc}</p>
                                {svc.items.length > 0 && (
                                    <div class="flex flex-wrap gap-2 mt-4">
                                        {svc.items.map(item => (
                                            <span class="inline-flex items-center text-xs font-heading font-semibold px-2.5 py-1 rounded-full"
                                                  style="background: rgba(71,106,51,0.08); color: var(--color-cactus-green);">{item}</span>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Avantages -->
    <section class="py-24" style="background: var(--color-cloud);">
        <div class="max-w-[800px] mx-auto px-6">
            <SectionHeader label="Pourquoi nous choisir" title="Pourquoi Cactus pour vos migrations ?" />
            <FeatureTable rows={[
                { label: 'Garantie de résultat', value: 'Nous nous engageons sur le succès de la migration, pas sur des heures de travail.' },
                { label: 'Zero Downtime', value: 'Migration progressive — votre activité continue pendant la transition.' },
                { label: 'Audit BDD profond', value: 'Nous résolvons des anomalies que les intégrateurs Sage/SAP ne trouvent pas.' },
                { label: '20 ans d\'expérience', value: 'Des dizaines de migrations complexes réussies depuis 2006.' },
                { label: 'Transparence radicale', value: 'Si c\'est impossible, nous vous le disons — avant de facturer.' },
                { label: 'Indépendance', value: 'Nous recommandons la meilleure cible, pas celle qui nous arrange.' },
            ]} />
        </div>
    </section>

    <!-- Cas clients -->
    <section class="py-24">
        <div class="max-w-[1200px] mx-auto px-6">
            <SectionHeader label="Cas clients" title="Ils nous font confiance pour leurs données" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-2">
                <CaseStudyCard badge="Données massives" client="Avon Beauty Products"
                    description="Interfaçage complexe AS400 ↔ SQL Server, traitement de données massives, création de tableaux de bord."
                    tags={['AS400', 'SQL Server', 'BI']} href={p('/resultats/cas-clients/')} delay={1} />
                <CaseStudyCard badge="Depuis 2007" client="Autodistribution"
                    description="Diagnostic direct en base de données pour synchroniser l'ERP Sage X3 avec la comptabilité."
                    tags={['Sage X3', 'Diagnostic BDD']} href={p('/resultats/cas-clients/')} delay={2} />
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="py-24" style="background: var(--color-cloud);">
        <div class="max-w-[800px] mx-auto px-6">
            <SectionHeader label="FAQ" title="FAQ — Migration & Données" />
            <FaqAccordion items={[
                { question: 'Combien de temps dure une migration ?', answer: 'Cela dépend du volume de données et de la complexité. Excel → ERP : quelques semaines. AS400 → SQL Server : 2-3 mois. Votre activité continue pendant la transition.' },
                { question: 'Que se passe-t-il si la migration échoue ?', answer: 'Nous offrons une garantie de résultat. Nous ne considérons la mission terminée que lorsque vos données sont correctement migrées, vérifiées et opérationnelles.' },
                { question: 'Pouvez-vous récupérer des données sur un serveur endommagé ?', answer: 'Oui, sous réserve que les secteurs de stockage n\'aient pas été physiquement réinitialisés. Diagnostic préalable honnête.' },
                { question: 'Mon intégrateur n\'arrive pas à résoudre un problème de synchronisation ?', answer: 'C\'est notre spécialité. Nous intervenons comme experts de dernier recours grâce à notre capacité de diagnostic direct en base de données.' },
            ]} />
        </div>
    </section>

    <UrgencyBanner
        title="Migration échouée par un autre prestataire ?"
        text="Nous reprenons les projets en difficulté et terminons le travail."
        ctaHref={p('/urgence/')}
        ctaLabel="Demande d'urgence"
    />

    <FinalCta
        title="Vos données méritent mieux qu'un copier-coller"
        text="Nous évaluerons la faisabilité, le calendrier et le risque — gratuitement et sans engagement."
        ctaLabel="Contactez-nous"
        ctaHref={p('/contact/') + '?besoin=migration'}
        phone="+212 5 22 34 35 45"
    />
</BaseLayout>
