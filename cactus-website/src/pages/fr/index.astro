         SECTION 9: URGENCY
         ═══════════════════════════════════════ -->
    <section class="relative text-center py-16 overflow-hidden" style="background: linear-gradient(135deg, var(--color-earth-brown) 0%, var(--color-earth-deep) 100%);">
        <!-- Glow -->
        <div class="absolute w-[500px] h-[500px] rounded-full -top-[200px] -right-[100px] pointer-events-none" style="background: radial-gradient(circle, rgba(219,204,99,0.08) 0%, transparent 60%);"></div>
        <div class="max-w-[1200px] mx-auto px-6 relative z-[1]">
            <p class="font-heading font-semibold text-xs uppercase tracking-widest mb-4 reveal" style="color: var(--color-gold);">{t('urgency.label')}</p>
            <h2 class="font-heading font-bold text-white mb-4 reveal" style="font-size: clamp(1.4rem, 3vw, 2.2rem);">{t('urgency.title')}</h2>
            <div class="reveal mb-6">
                <a href={`tel:${t('urgency.phone').replace(/\s+/g, '')}`}
                   aria-label={`Appeler le ${t('urgency.phone')}`}
                   class="inline-flex items-center justify-center gap-3 sm:gap-4 px-6 py-3 sm:px-8 sm:py-3.5 rounded-full border font-heading font-extrabold text-white whitespace-nowrap min-h-[44px] transition-all duration-200 ease-out hover:scale-[1.025] focus:scale-[1.025] hover:border-[var(--color-gold)] focus:border-[var(--color-gold)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-gold)]"
                   style="font-size: clamp(1.5rem, 4vw, 2.5rem); letter-spacing: 0.015em; font-variant-numeric: tabular-nums; border-color: rgba(219, 204, 99, 0.35); color: var(--color-gold);">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[0.6em] h-[0.6em] shrink-0" style="color: var(--color-gold);" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    <span>{t('urgency.phone')}</span>
                </a>
            </div>
            <p class="text-base mb-8 reveal" style="color: rgba(255,255,255,0.7);">{t('urgency.text')}</p>
            <div class="reveal">
                <a href={p('/urgence/')} class="inline-flex items-center gap-2 font-heading font-semibold text-base rounded-full px-8 py-4 transition-all hover:-translate-y-0.5 hover:shadow-lg" style="background: var(--color-gold); color: var(--color-cactus-dark);">
                    {t('urgency.cta')}
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                </a>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════
         SECTION 10: FINAL CTA
         ═══════════════════════════════════════ -->
    <section class="relative text-center py-24 dot-grid" style="background: var(--color-cactus-dark);">
        <div class="max-w-[1200px] mx-auto px-6 relative z-[1]">
            <h2 class="font-heading font-bold text-white mb-4 reveal" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">{t('cta_final.title')}</h2>
            <p class="text-base max-w-[520px] mx-auto mb-8 reveal" style="color: rgba(238,238,238,0.7);">{t('cta_final.text')}</p>
            <div class="reveal">
                <a href={p('/contact/')} class="inline-flex items-center gap-2 font-heading font-semibold text-base rounded-full px-8 py-4 text-white transition-all hover:-translate-y-0.5 hover:shadow-lg" style="background: var(--color-cactus-green);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                    {t('cta.contact')}
                </a>
            </div>
            <p class="font-heading font-semibold text-sm mt-6 reveal" style="color: var(--color-gold);">
                {t('cta_final.phone')}
                <a href={`tel:${t('urgency.phone').replace(/\s+/g, '')}`} aria-label={`Appeler le ${t('urgency.phone')}`} class="inline-flex items-center gap-1.5 ml-1 transition-opacity hover:opacity-80 underline underline-offset-4 decoration-[var(--color-gold)]/40 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-gold)]" style="font-variant-numeric: tabular-nums;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[0.9em] h-[0.9em] shrink-0 inline-block" style="color: var(--color-gold);" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    <span>{t('urgency.phone')}</span>
                </a>
            </p>
        </div>
    </section>

    <!-- tsParticles Slim CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/tsparticles-slim@2.12.0/tsparticles.slim.bundle.min.js"></script>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof tsParticles === 'undefined') return;

            tsParticles.load("tsparticles", {
                fpsLimit: 60,
                fullScreen: {
                    enable: false
                },
                particles: {
                    number: {
                        value: 70,
                        density: {
                            enable: true,
                            area: 900
                        }
                    },
                    color: {
                        value: ["#DBCC63", "#476A33"]
                    },
                    shape: {
                        type: "circle"
                    },
                    opacity: {
                        value: 0.15
                    },
                    size: {
                        value: { min: 1.5, max: 4.5 }
                    },
                    links: {
                        enable: false,
                        distance: 140,
                        color: "#EEEEEE",
                        opacity: 0.06,
                        width: 1.2
                    },
                    move: {
                        enable: true,
                        speed: 1.2,
                        direction: "none",
                        random: false,
                        straight: false,
                        outModes: {
                            default: "out"
                        }
                    }
                },
                interactivity: {
                    detectsOn: "window",
                    events: {
                        onHover: {
                            enable: true,
                            mode: "grab"
                        },
                        onClick: {
                            enable: true,
                            mode: "push"
                        },
                        resize: true
                    },
                    modes: {
                        grab: {
                            distance: 180,
                            links: {
                                opacity: 0.15
                            }
                        },
                        push: {
                            quantity: 4
                        }
                    }
                },
                detectRetina: true
            });
        });
    </script>
</BaseLayout>
