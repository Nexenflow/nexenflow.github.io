---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getLocalePath } from '../../i18n/utils';

const lang = 'fr';
const p = (path: string) => getLocalePath(lang, path);
---

<BaseLayout
    title="Politique de Confidentialité — Cactus Informatique"
    description="Politique de confidentialité de Cactus Informatique. Protection des données personnelles, cookies et droits des utilisateurs."
>
    <PageHero
        label="Confidentialité"
        title="Politique de "
        titleHighlight="confidentialité"
        subtitle=""
        breadcrumbs={[{ label: 'Politique de Confidentialité' }]}
        lang={lang}
    />

    <section class="py-24">
        <div class="max-w-[800px] mx-auto px-6 prose-legal">
            <h2>Introduction</h2>
            <p>Cactus Informatique s'engage à protéger la vie privée des visiteurs de son site internet et de ses clients. Cette politique de confidentialité décrit les types de données personnelles que nous collectons, comment nous les utilisons, les conservons et les protégeons.</p>

            <h2>Responsable du traitement</h2>
            <p>
                <strong>Cactus Informatique</strong><br />
                70 Allée des Phoenix, Casablanca 20250, Maroc<br />
                Email : contact@cactus.net.ma<br />
                Téléphone : +212 5 22 34 35 45
            </p>

            <h2>Données collectées</h2>
            <h3>Via les formulaires de contact</h3>
            <p>Lorsque vous utilisez nos formulaires de contact ou d'urgence, nous collectons :</p>
            <ul>
                <li>Nom complet</li>
                <li>Nom de l'entreprise</li>
                <li>Adresse email professionnelle</li>
                <li>Numéro de téléphone</li>
                <li>Nature de votre besoin</li>
                <li>Contenu de votre message</li>
            </ul>

            <h3>Via la navigation sur le site</h3>
            <ul>
                <li>Adresse IP (anonymisée)</li>
                <li>Type de navigateur et système d'exploitation</li>
                <li>Pages visitées et durée de visite</li>
                <li>Source de trafic (moteur de recherche, lien direct, etc.)</li>
            </ul>

            <h2>Utilisation des données</h2>
            <p>Vos données personnelles sont utilisées exclusivement pour :</p>
            <ul>
                <li>Répondre à vos demandes de contact ou d'urgence</li>
                <li>Vous fournir les services demandés</li>
                <li>Améliorer notre site internet et nos services</li>
                <li>Vous envoyer des communications commerciales (uniquement avec votre consentement préalable)</li>
            </ul>
            <p><strong>Nous ne vendons, ne louons et ne partageons jamais vos données personnelles avec des tiers à des fins commerciales.</strong></p>

            <h2>Durée de conservation</h2>
            <ul>
                <li><strong>Données de contact :</strong> conservées pendant 3 ans après le dernier contact</li>
                <li><strong>Données de navigation :</strong> conservées pendant 13 mois maximum</li>
                <li><strong>Données contractuelles :</strong> conservées pendant la durée du contrat et les obligations légales applicables</li>
            </ul>

            <h2>Cookies</h2>
            <p>Ce site utilise des cookies pour :</p>
            <ul>
                <li><strong>Cookies essentiels :</strong> fonctionnement du site (session, sécurité CSRF)</li>
                <li><strong>Cookies analytiques :</strong> mesure d'audience anonymisée</li>
            </ul>
            <p>Vous pouvez gérer vos préférences de cookies via la bannière de consentement affichée lors de votre première visite.</p>

            <h2>Vos droits</h2>
            <p>Conformément à la législation marocaine sur la protection des données personnelles (Loi n° 09-08), vous disposez des droits suivants :</p>
            <ul>
                <li><strong>Droit d'accès :</strong> obtenir une copie de vos données personnelles</li>
                <li><strong>Droit de rectification :</strong> corriger des données inexactes</li>
                <li><strong>Droit de suppression :</strong> demander la suppression de vos données</li>
                <li><strong>Droit d'opposition :</strong> vous opposer au traitement de vos données</li>
            </ul>
            <p>
                Pour exercer ces droits, contactez-nous :<br />
                <strong>Email :</strong> contact@cactus.net.ma<br />
                <strong>Courrier :</strong> Cactus Informatique, 70 Allée des Phoenix, Casablanca 20250, Maroc
            </p>

            <h2>Sécurité des données</h2>
            <p>Nous mettons en œuvre des mesures techniques et organisationnelles appropriées pour protéger vos données personnelles contre la perte, le vol, l'accès non autorisé, la divulgation ou la modification. En tant qu'experts en cybersécurité, la protection des données est au cœur de notre métier.</p>

            <h2>Modifications</h2>
            <p>Cette politique de confidentialité peut être modifiée à tout moment. La date de dernière mise à jour est indiquée ci-dessous.</p>

            <h2>Contact</h2>
            <p>
                Pour toute question relative à cette politique de confidentialité :<br />
                <strong>Email :</strong> contact@cactus.net.ma<br />
                <strong>Téléphone :</strong> +212 5 22 34 35 45
            </p>

            <p><em>Dernière mise à jour : juillet 2026</em></p>
        </div>
    </section>
</BaseLayout>
