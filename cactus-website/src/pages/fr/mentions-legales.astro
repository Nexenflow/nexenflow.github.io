---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getLocalePath } from '../../i18n/utils';

const lang = 'fr';
const p = (path: string) => getLocalePath(lang, path);
---

<BaseLayout
    title="Mentions Légales — Cactus Informatique"
    description="Mentions légales du site Cactus Informatique. Informations sur l'éditeur, l'hébergeur et les conditions d'utilisation."
>
    <PageHero
        label="Mentions légales"
        title="Mentions "
        titleHighlight="légales"
        subtitle=""
        breadcrumbs={[{ label: 'Mentions Légales' }]}
        lang={lang}
    />

    <section class="py-24">
        <div class="max-w-[800px] mx-auto px-6 prose-legal">
            <h2>Éditeur du site</h2>
            <p>
                <strong>Cactus Informatique</strong><br />
                Société à responsabilité limitée (SARL)<br />
                Capital social : 300 000 MAD
            </p>
            <p>
                <strong>Siège social :</strong><br />
                70 Allée des Phoenix<br />
                Casablanca 20250, Maroc
            </p>
            <p>
                <strong>Directeur de la publication :</strong> Omar
            </p>
            <p>
                <strong>Téléphone :</strong> +212 5 22 34 35 45<br />
                <strong>Email :</strong> contact@cactus.net.ma<br />
                <strong>Site web :</strong> www.cactus.ma
            </p>

            <h2>Hébergeur</h2>
            <p>À compléter avec les informations de l'hébergeur choisi.</p>

            <h2>Propriété intellectuelle</h2>
            <p>L'ensemble du contenu de ce site (textes, images, logos, icônes, éléments graphiques, vidéos) est la propriété exclusive de Cactus Informatique ou de ses partenaires. Toute reproduction, distribution, modification ou utilisation de ce contenu sans autorisation préalable écrite est interdite.</p>
            <p>Le logo et la marque « Cactus Informatique » sont des marques déposées. Leur utilisation sans autorisation est interdite.</p>

            <h2>Limitation de responsabilité</h2>
            <p>Cactus Informatique s'efforce de fournir sur ce site des informations aussi précises que possible. Toutefois, Cactus Informatique ne pourra être tenu responsable des omissions, des inexactitudes et des carences dans la mise à jour, qu'elles soient de son fait ou du fait des tiers partenaires qui lui fournissent ces informations.</p>

            <h2>Liens hypertextes</h2>
            <p>Ce site peut contenir des liens hypertextes vers d'autres sites internet. Cactus Informatique ne dispose d'aucun contrôle sur le contenu de ces sites tiers et décline toute responsabilité quant à leur contenu.</p>

            <h2>Droit applicable</h2>
            <p>Les présentes mentions légales sont soumises au droit marocain. En cas de litige, les tribunaux de Casablanca seront seuls compétents.</p>

            <h2>Contact</h2>
            <p>
                Pour toute question relative aux présentes mentions légales, contactez-nous :<br />
                <strong>Email :</strong> contact@cactus.net.ma<br />
                <strong>Téléphone :</strong> +212 5 22 34 35 45
            </p>
        </div>
    </section>
</BaseLayout>
