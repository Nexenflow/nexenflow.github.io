---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import MethodologySteps from '../../../components/MethodologySteps.astro';
import StatsBar from '../../../components/StatsBar.astro';
import FinalCta from '../../../components/FinalCta.astro';
import { getLocalePath } from '../../../i18n/utils';

const lang = 'fr';
const p = (path: string) => getLocalePath(lang, path);

const differentiators = [
    { title: 'Facturation au résultat', desc: 'Nous nous engageons sur la résolution effective de vos problèmes. Pas de décompte d\'heures.' },
    { title: 'Posture de « Pompier »', desc: 'Nous intervenons là où d\'autres prestataires ont échoué : ERP bloqués, migrations ratées, infrastructures compromises.' },
    { title: 'Indépendance totale', desc: 'Aucune dépendance éditeur. Nos recommandations sont objectivement les meilleures pour vous.' },
    { title: 'Transparence radicale', desc: 'Si c\'est impossible, nous le disons avant de facturer. Si une solution moins chère existe, nous la recommandons.' },
    { title: 'Traçabilité complète', desc: 'Chaque décision technique est documentée et traçable jusqu\'aux spécifications d\'origine.' },
    { title: 'DSI externalisé', desc: 'Pilotage de votre stratégie technologique sur le long terme. 8 experts, agilité maximale.' },
];
---

<BaseLayout
    title="Notre Méthodologie — Facturation au Résultat"
    description="Facturation au résultat, indépendance totale, posture de pompier technique. Découvrez l'approche unique de Cactus Informatique au Maroc."
>
    <PageHero
        label="Méthodologie"
        title="L'ingénierie du "
        titleHighlight="résultat"
        subtitle="La plupart des prestataires IT facturent à l'heure. Nous avons fait un choix radical : la facturation au résultat."
        breadcrumbs={[
            { label: 'Résultats', href: p('/resultats/') },
            { label: 'Méthodologie' },
        ]}
        lang={lang}
        ctaHref={p('/contact/') + '?besoin=audit'}
        ctaLabel="Travaillons ensemble"
            imageSrc="/imgs/resized_30pct_webp/methodologie.webp"
        imageAlt="Illustration methodologie"
    />

    <!-- 4 Pillars -->
    <section class="py-24">
        <div class="max-w-[1200px] mx-auto px-6">
            <SectionHeader
                label="Les 4 piliers"
                title="Notre méthodologie en 4 étapes"
                subtitle="Ce cadre méthodologique nous impose une rigueur absolue — et garantit vos résultats."
            />
            <MethodologySteps
                steps={[
                    { num: '1', title: 'Diagnostic', text: 'Nous identifions les vrais problèmes — pas seulement les symptômes. Analyse de votre infrastructure, données, processus.' },
                    { num: '2', title: 'Conception', text: 'Architecture technique sur mesure avec traçabilité complète. La meilleure approche, indépendamment de tout éditeur.' },
                    { num: '3', title: 'Déploiement', text: 'Mise en production progressive et maîtrisée. Tests à chaque étape, philosophie Zéro Faille.' },
                    { num: '4', title: 'Accompagnement', text: 'Formation, support continu, maintenance proactive. Un partenariat, pas une prestation ponctuelle.' },
                ]}
                expanded={true}
            />
        </div>
    </section>

    <!-- Differentiators Grid -->
    <section class="py-24" style="background: var(--color-cloud);">
        <div class="max-w-[1200px] mx-auto px-6">
            <SectionHeader
                label="Ce qui nous différencie"
                title="Ce qui nous différencie structurellement"
            />
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-2">
                {differentiators.map((diff, i) => (
                    <div class={`bg-white border rounded-2xl p-7 reveal reveal-delay-${(i % 3) + 1}`}
                         style="border-color: var(--color-cloud-dark);">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
                             style="background: rgba(219,204,99,0.15);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-amber);">
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <h3 class="font-heading font-semibold text-base mb-2" style="color: var(--color-ink);">{diff.title}</h3>
                        <p class="text-sm leading-relaxed" style="color: var(--color-ink-soft);">{diff.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- DSI externalisé -->
    <section class="py-24 relative dot-grid" style="background: var(--color-cactus-dark);">
        <div class="max-w-[800px] mx-auto px-6 text-center relative z-10">
            <SectionHeader
                label="Notre modèle"
                title="Le modèle DSI externalisé"
                subtitle="Cactus ne se positionne pas comme un prestataire ponctuel, mais comme votre Directeur des Systèmes d'Information externalisé."
                variant="dark"
                align="center"
            />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left mt-4">
                {[
                    'Pilotage de votre stratégie technologique',
                    'Vision globale de votre écosystème IT',
                    'Anticipation des évolutions et des risques',
                    'Interlocuteur unique pour tous vos besoins',
                ].map((item, i) => (
                    <div class={`flex items-start gap-3 reveal reveal-delay-${i + 1}`}>
                        <svg class="shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="m9 12 2 2 4-4"/></svg>
                        <span class="text-sm" style="color: rgba(238,238,238,0.7);">{item}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <StatsBar stats={[
        { count: '20', suffix: ' ans', label: "de méthodologie éprouvée" },
        { count: '50', prefix: '+', label: 'missions critiques réussies' },
        { count: '17', suffix: ' ans', label: 'partenariat le plus long' },
        { count: '100', suffix: '%', label: 'facturation au résultat' },
    ]} />

    <FinalCta
        title="Prêt à travailler avec un partenaire qui s'engage ?"
        text="Vos résultats sont notre facture."
        ctaLabel="Contactez-nous"
        ctaHref={p('/contact/') + '?besoin=audit'}
        phone="+212 5 22 34 35 45"
    />
</BaseLayout>
